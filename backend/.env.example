NODE_ENV=development
# If you see EADDRINUSE, change this (e.g. 4001) or stop the other server on this port
PORT=4000
MONGODB_URI=mongodb://localhost:27017/bus_tracking
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*

# Optional: Redis for nearest-bus cache (leave empty to disable)
REDIS_URL=

# Socket.IO CORS (comma-separated origins or *)
SOCKET_CORS_ORIGIN=*
